%% Frontend Architecture — IoT Monitoring System
flowchart TB
    subgraph Browser["Operator Web Browser"]
        UI["React 18 + TypeScript SPA<br/>Material UI Theme"]
    end

    subgraph Pages["Pages — React Router v6"]
        P0["/login — LoginPage"]
        P1["/dashboard — Dashboard"]
