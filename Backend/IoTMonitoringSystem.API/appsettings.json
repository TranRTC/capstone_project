{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=IoTMonitoringDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "EnableTls": false,
    "AllowUntrustedTls": false,
    "Username": "",
    "Password": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Jwt": {
    "Key": "CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS!!",
    "Issuer": "IoTMonitoringSystem",
    "Audience": "IoTMonitoringFrontend",
    "ExpiryHours": "8"
  },
  "AdminSeed": {
    "Username": "admin",
    "Password": "Admin@123",
    "Email": "admin@iot.local"
  },
  "Agent": {
    "Enabled": true,
    "Model": "gpt-4o-mini",
    "MaxHistoryMessages": 10,
    "RequestTimeoutSeconds": 60,
    "Llm": {
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": ""
    },
    "Proactive": {
      "Enabled": true,
      "DeviceOfflineMinutes": 15,
      "MqttUnhealthyMinutes": 5,
      "SweepIntervalSeconds": 60,
      "InsightCooldownMinutes": 15,
      "MaxInsightsPerHour": 20
    },
    "Actions": {
      "Enabled": true,
      "ProposalExpiryMinutes": 10,
      "MaxPendingPerUser": 1
    },
    "IntentRouter": {
      "Enabled": true
    },
    "Sessions": {
      "Enabled": true
    },
    "Rag": {
      "Enabled": true,
      "RepositoryRootRelative": "../..",
      "MaxChunks": 5,
      "ChunkSizeChars": 1800,
      "ChunkOverlapChars": 150,
      "IncludePaths": [
        "README.md",
        "Documents/001_Overview.md",
        "Documents/006_APIDocumentation.md",
        "Documents/008_DeploymentGuide.md",
        "Documents/009_ImplementationGuide.md",
        "Documents/010_UserManual.md",
        "Frontend/iot-monitoring-frontend/README.md"
      ]
    },
    "ScheduledReports": {
      "Enabled": true,
      "DailyDigestHourLocal": 8,
      "WeeklyDigestDay": "Monday",
      "Timezone": "Central Standard Time"
    }
  },
  "Mcp": {
    "Enabled": true,
    "HttpPath": "/mcp",
    "RequireApiKey": true,
    "ApiKey": "change-me-in-production"
  },
  "AllowedHosts": "*"
}
