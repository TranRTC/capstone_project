{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=IoTMonitoringDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "EnableTls": false,
    "AllowUntrustedTls": false,
    "Username": "",
    "Password": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "Jwt": {
    "Key": "CHANGE_THIS_SECRET_KEY_IN_PRODUCTION_MIN_32_CHARS!!",
    "Issuer": "IoTMonitoringSystem",
    "Audience": "IoTMonitoringFrontend",
    "ExpiryHours": "8"
  },
  "AdminSeed": {
    "Username": "admin",
    "Password": "Admin@123",
    "Email": "admin@iot.local"
  },
  "Agent": {
    "Enabled": true,
    "Model": "gpt-4o-mini",
    "MaxHistoryMessages": 10,
    "RequestTimeoutSeconds": 60,
    "Llm": {
      "BaseUrl": "https://api.openai.com/v1",
      "ApiKey": ""
    },
    "Proactive": {
      "Enabled": true,
      "DeviceOfflineMinutes": 15,
      "MqttUnhealthyMinutes": 5,
      "SweepIntervalSeconds": 60,
      "InsightCooldownMinutes": 15,
      "MaxInsightsPerHour": 20
    }
  },
  "AllowedHosts": "*"
}
