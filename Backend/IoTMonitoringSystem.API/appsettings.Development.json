{
  "Jwt": {
    "Key": "DEV_SECRET_KEY_CHANGE_IN_PROD_MIN_32_CHARS!!!!!",
    "Issuer": "IoTMonitoringSystem",
    "Audience": "IoTMonitoringFrontend",
    "ExpiryHours": "8"
  },
  "Mqtt": {
    "EnableTls": false,
    "AllowUntrustedTls": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  },
  "Agent": {
    "Enabled": true,
    "Model": "llama3.2",
    "MaxHistoryMessages": 10,
    "RequestTimeoutSeconds": 120,
    "Llm": {
      "BaseUrl": "http://localhost:11434/v1",
      "ApiKey": "ollama"
    },
    "Proactive": {
      "Enabled": true,
      "DeviceOfflineMinutes": 15,
      "MqttUnhealthyMinutes": 5,
      "SweepIntervalSeconds": 60,
      "InsightCooldownMinutes": 15,
      "MaxInsightsPerHour": 20
    },
    "Actions": {
      "Enabled": true,
      "ProposalExpiryMinutes": 10,
      "MaxPendingPerUser": 1
    },
    "Rag": {
      "Enabled": true,
      "RepositoryRootRelative": "../..",
      "MaxChunks": 5,
      "ChunkSizeChars": 1800,
      "ChunkOverlapChars": 150,
      "IncludePaths": [
        "README.md",
        "Documents/001_Overview.md",
        "Documents/006_APIDocumentation.md",
        "Documents/008_DeploymentGuide.md",
        "Documents/009_ImplementationGuide.md",
        "Documents/010_UserManual.md",
        "Frontend/iot-monitoring-frontend/README.md"
      ]
    },
    "ScheduledReports": {
      "Enabled": true,
      "DailyDigestHourLocal": 8,
      "WeeklyDigestDay": "Monday",
      "Timezone": "Central Standard Time"
    }
  },
  "Mcp": {
    "Enabled": true,
    "HttpPath": "/mcp",
    "RequireApiKey": false,
    "ApiKey": "dev-mcp-key"
  }
}
